---
layout: base.njk
---

<main class="project-page">
  <a href="/projects/" class="project-back-button" aria-label="Back to Projects">←</a>
<header class="project-header">
<h1>{{ title }}</h1>
{% if cover %}
<img class="project-cover-image" src="{{ cover }}" alt="Cover image for {{ title }}">
{% endif %}
<div class="project-meta-top">
{%- if date %}<time datetime="{{ date }}">{{ date }}</time>{% endif -%}
{%- if role %}<span class="project-role">{{ role }}</span>{% endif -%}
</div>
</header>


<div class="project-body-grid">


<aside class="project-sidebar">
{% if tech %}
<h1 class="manrope-500">Tech Stack</h1>
<ul class="tech-list">{% for t in tech %}<li>{{ t }}</li>{% endfor %}</ul>
{% endif %}

{%- if link or repo -%}
<h2>Links</h2>
<div class="project-links">
  {% if link %}<a class="btn" href="{{ link }}" target="_blank" rel="noopener">Visit site</a>{% endif %}
  {% if repo %}<a class="btn secondary" href="{{ repo }}" target="_blank" rel="noopener">View repo</a>{% endif %}
</div>
{% endif %}

</aside>

<section class="project-body">{{ content | safe }}</section>

</div>
</main>