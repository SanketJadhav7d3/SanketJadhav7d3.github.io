<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">


  <!-- Devicon icons -->
  <link rel="stylesheet" type='text/css' href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css" />
          

  <!-- Local Styles -->
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="stylesheet" href="/css/links_styles.css">
  <link rel="stylesheet" href="/css/timeline.css">
  <link rel="stylesheet" href="/css/projects.css">
  <link rel="stylesheet" href="/css/projects-cosmos.css">
  <link rel="stylesheet" href="/css/footer.css">
  <link rel="stylesheet" href="/css/gradient.css">
  <link rel="stylesheet" href="/css/blog.css">
  <link rel="stylesheet" href="/css/fonts.css">
  <link rel="stylesheet" href="/css/project-page.css">
  <link rel="stylesheet" href="/css/radial-nav.css">
  <link rel="stylesheet" href="/css/bottom-nav.css">
  <link rel="stylesheet" href="/css/meteors.css">
  <link rel="stylesheet" href="/css/marquee.css">
  <link rel="stylesheet" href="/css/tech-stack.css">
  <link rel="stylesheet" href="/css/stars.css">

  
  <link rel="stylesheet" href="/katex/katex.min.css">

  <script defer src="/katex/katex.min.js"></script>
  <script defer src="/katex/contrib/auto-render.min.js"></script>
  
</head>

<style>
  /* 1. Fluid Reset & Global Box Sizing */
  * {
    box-sizing: border-box;
  }

  html, body {
    margin: 0;
    padding: 0;
    width: 100%;
    overflow-x: hidden; /* Prevents unwanted horizontal scrolling on mobile */
  }

  /* 2. Responsive Cursors (Disabled on touch devices for better UX) */
  @media (hover: hover) {
    html, body {
      cursor: url('/css/Arrows/Arrow4min.png'), auto;
    }
    a, button, [role="button"], input[type="submit"] {
      cursor: url('/css/Arrows/Hand3min.png'), pointer;
    }
  }

  /* 3. Fluid Layout Containers */
  .page-container {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    width: 100%;
  }

  .main-content {
    flex: 1;
    width: 100%;
    display: block;
    padding: 0; /* Removing side padding here to allow children to be truly full-width on mobile */
  }

  .center-bar, .home-center-bar {
    width: 90%;
    max-width: 850px; /* Narrower measure for better reading experience on desktop */
    margin: 0 auto;
    padding: 4rem 3rem; /* Enhanced padding for a more spacious feel on large screens */
  }

  /* 4. Fluid Media */
  .hero-image {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 0 auto;
  }

  /* 5. Mobile-Specific Breakpoint (approx. for most phones) */
  @media screen and (max-width: 600px) {
    .main-content {
      padding: 0;
    }
    
    /* Mobile-specific layout improvements */
    .center-bar, .home-center-bar {
      width: 100%; /* Occupy the whole screen on mobile */
      padding: 0 1.25rem; /* Internal padding so text doesn't touch the screen edges */
    }

    /* Scale down headers on mobile */
    .pixel-art-header {
      font-size: 2.2rem;
    }
    .pixel-art-secondary-header {
      font-size: 1.6rem;
    }
  }

  /* 6. Bottom Navigation Flexibility */
  
  /* When the screen is too narrow for all icons (roughly 550px), 
     hide the separator and social media links to prioritize site navigation. */
  @media screen and (max-width: 550px) {
    .nav-separator,
    .nav-separator ~ .bottom-nav-item {
      display: none;
    }
    
    .bottom-nav {
      justify-content: space-around; /* Distribute the remaining 4 items evenly */
    }
  }

  /* On very small screens (400px and below), hide the labels 
     entirely to keep the bar clean and prevent overflow. */
  @media screen and (max-width: 400px) {
    .nav-item-label {
      display: none;
    }
  }
</style>

<body>
  <div class="page-container">

    <!-- Star Panning Effect -->
    <div class="stars-background" aria-hidden="true"></div>

    <!-- Meteor Shower Effect -->
    <div class="meteors" aria-hidden="true">
      <!-- Meteors are generated by JavaScript -->
    </div>
    
    {% if homePageImage %}
      <div class="pixel-art">
        <img src="{{ homePageImage }}" alt="{{ title }} hero image" class="hero-image">
      </div>
    {% endif %}

    <!-- New Bottom Navigation Bar -->
    <nav class="bottom-nav" aria-label="Main navigation">
      <div class="bottom-nav-item">
        <a href="/" aria-label="Home"><i class="fa-solid fa-house-chimney"></i></a>
        <span class="nav-item-label">Home</span>
      </div>
      <div class="bottom-nav-item">
        <a href="/projects/" aria-label="Projects"><i class="fa-solid fa-layer-group"></i></a>
        <span class="nav-item-label">Projects</span>
      </div>
      
      <div class="bottom-nav-item">
        <a href="/blogs/" aria-label="Blog"><i class="fa-solid fa-pen-nib"></i></a>
        <span class="nav-item-label">Blog</span>
      </div>
      

      <div class="bottom-nav-item">
        <button id="toggle-effects-btn" type="button" aria-label="Toggle background effects" aria-pressed="false">
          <i class="fa-solid fa-meteor"></i>
        </button>
        <span class="nav-item-label">Stargaze</span>
      </div>
      
      <!-- Separator -->
      <div class="nav-separator"></div>
      
      <div class="bottom-nav-item">
        <a href="https://github.com/SanketJadhav7d3" target="_blank" rel="noopener noreferrer" aria-label="GitHub"><i class="fa-brands fa-github"></i></a>
        <span class="nav-item-label">GitHub</span>
      </div>
      <div class="bottom-nav-item">
        <a href="https://linkedin.com/in/sanket-jadhav-b01398237" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"><i class="fa-brands fa-linkedin-in"></i></a>
        <span class="nav-item-label">LinkedIn</span>
      </div>
      <div class="bottom-nav-item">
        <a href="https://x.com/SanketJadhav7d3" target="_blank" rel="noopener noreferrer" aria-label="X"><i class="fa-brands fa-x-twitter"></i></a>
        <span class="nav-item-label">X</span>
      </div>
    </nav>

    <!-- Main Content -->
    <div class="main-content">

      <div class="{{ 'home-center-bar' if isHomePage else 'center-bar'}}">
        {{ content | safe }}
      </div>
    </div>
      

    <!-- START: Minimal Footer -->
    <footer class="site-footer" role="contentinfo" aria-label="Site footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <a href="/" class="logo montserrat-400">Sanket</a>
          <p class="tagline body-text-font">
            small things, carefully made — <span class="current-year"></span>
          </p>
        </div>

        <div class="footer-social" aria-label="Social links">
        </div>
      </div>

      <div class="footer-bottom">
        <a id="back-to-top" href="#" class="back-to-top body-text-font" aria-label="Back to top">Back to top ↑</a>
      </div>
    </footer>
    <!-- END: Minimal Footer -->

  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // --- Effects Toggle ---
      const toggleBtn = document.getElementById('toggle-effects-btn');
      const body = document.body;
      const meteorContainer = document.querySelector('.meteors');
      let meteorTimeoutId = null;

      // --- Meteor Logic ---
      const centerBar = document.querySelector('.center-bar, .home-center-bar');
      let screenWidth = window.innerWidth;
      let rightGutterWidth = 0;

      function updateLayout() {
        if (!centerBar) return;
        const style = window.getComputedStyle(centerBar);
        rightGutterWidth = parseFloat(style.paddingRight);
        screenWidth = window.innerWidth;
      }

      function createMeteor() {
        if (!meteorContainer) return;
        const meteor = document.createElement('span');

        // Widen the origin points to a much larger area in the top-right, completely off-screen,
        // so they appear more randomly and from a wider, non-visible source.
        const startX = screenWidth + (Math.random() * 500);      // Start 0-500px off-screen to the right
        const startY = -200 - (Math.random() * 500); // Start 200-700px above the screen

        meteor.style.left = `${startX}px`;
        meteor.style.top = `${startY}px`;

        meteor.style.animationName = 'animate-meteor-left';
        meteor.style.animationDuration = `${Math.random() * 2 + 3}s`; // 3-5s duration
        meteor.addEventListener('animationend', () => meteor.remove());
        meteorContainer.appendChild(meteor);
      }

      function scheduleNextMeteor() {
        const delay = (Math.random() * 4 + 4) * 1000; // 4 to 8 seconds
        meteorTimeoutId = setTimeout(() => {
          createMeteor();
          scheduleNextMeteor();
        }, delay);
      }

      function stopMeteorScheduler() {
        if (meteorTimeoutId) {
          clearTimeout(meteorTimeoutId);
          meteorTimeoutId = null;
        }
        if (meteorContainer) {
          meteorContainer.innerHTML = ''; // Clear existing meteors
        }
      }

      // --- Toggle State Management ---
      function setEffectsState(enabled) {
        if (enabled) {
          body.classList.remove('effects-off');
          toggleBtn.setAttribute('aria-pressed', 'true');
          localStorage.setItem('effectsEnabled', 'true');
          scheduleNextMeteor();
        } else {
          body.classList.add('effects-off');
          toggleBtn.setAttribute('aria-pressed', 'false');
          localStorage.setItem('effectsEnabled', 'false');
          stopMeteorScheduler();
        }
      }

      // Check localStorage for saved state, default to false (effects off)
      const effectsEnabled = localStorage.getItem('effectsEnabled') === 'true';

      // Set initial state on page load
      setEffectsState(effectsEnabled);

      toggleBtn.addEventListener('click', () => {
        const effectsAreOff = body.classList.contains('effects-off');
        setEffectsState(effectsAreOff); // Toggle to the opposite state
      });

      // Initial setup and listeners
      updateLayout();
      window.addEventListener('resize', updateLayout, { passive: true });
    });

    document.addEventListener("DOMContentLoaded", function () {
      renderMathInElement(document.body, {
        delimiters: [
          {left: "$$", right: "$$", display: true},
          {left: "$", right: "$", display: false}
        ]
      });
    });
  </script>
</body>
</html>
